# Handle line endings automatically for files detected as text
# and leave binary files untouched.
* text=auto

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout.
*.dart text
*.kts text
*.gradle text
*.xml text
*.json text
*.yaml text
*.md text

# Declare files that will always have LF line endings on checkout.
*.sh text eol=lf

# Ensure generated files have consistent line endings to avoid warnings
generated_plugin_registrant.cc text
generated_plugin_registrant.h text
generated_plugins.cmake text
GeneratedPluginRegistrant.swift text
